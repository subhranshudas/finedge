{
  "name": "finedge",
  "version": "1.0.0",
  "description": "Personal Finance & Expense Tracker API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "NODE_ENV=test npm run test:unit && NODE_ENV=test npm run test:integration",
    "test:unit": "NODE_ENV=test jest --config jest.config.js",
    "test:integration": "NODE_ENV=test jest --config jest.integration.config.js",
    "test:coverage": "NODE_ENV=test jest --config jest.coverage.config.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "envalid": "^8.1.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.0.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  }
}
